# HDIMS local environment
# Copy this file to .env and replace placeholder values.

# LLM Provider Configuration
LLM_PROVIDER=openai  # set to "groq" to use Groq API

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Groq
GROQ_API_KEY=your-groq-api-key

# Model Overrides (defaults to gpt-4o if using OpenAI)
LLM_TEXT_MODEL=gpt-4o
LLM_VISION_MODEL=gpt-4o

# Database
DATABASE_URL=mysql+pymysql://hdmis_user:hdmis_pass@localhost:3306/hdmis

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
REDIS_RESULT_BACKEND=redis://localhost:6379/1
USE_CELERY=False

# Product auth
SECRET_KEY=replace-with-a-long-random-secret-at-least-32-characters
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440
JWT_REFRESH_EXPIRY_DAYS=7
RATE_LIMIT_STORAGE_URI=memory://

# File storage
STORAGE_PATH=./storage
MAX_FILE_SIZE_MB=50

# Vector storage
QDRANT_URL=http://localhost:6333
QDRANT_STORAGE_PATH=./qdrant_storage

# Local development (MinIO via Docker)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=documents-storage
STORAGE_BACKEND=minio

# Production (Render-hosted MinIO)
# MINIO_ENDPOINT=https://your-minio.onrender.com


# Frontend API base URL
VITE_API_URL=http://localhost:8000

GROQ_API_KEY=
