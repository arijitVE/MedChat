# HDIMS local environment
# Copy this file to .env and replace placeholder values.

# LLM / OCR providers
OPENAI_API_KEY=your-openai-api-key
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/google-service-account.json

# Database
DATABASE_URL=mysql+pymysql://hdmis_user:hdmis_pass@localhost:3306/hdmis

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# Product auth
SECRET_KEY=replace-with-a-long-random-secret-at-least-32-characters
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440
JWT_REFRESH_EXPIRY_DAYS=7
RATE_LIMIT_STORAGE_URI=memory://

# File storage
STORAGE_PATH=./storage
MAX_FILE_SIZE_MB=50

# Vector storage
QDRANT_URL=
QDRANT_STORAGE_PATH=./qdrant_storage

# Frontend API base URL
VITE_API_URL=http://localhost:8000

# Confidence thresholds
OCR_CONFIDENCE_THRESHOLD=0.85
FIELD_CONFIDENCE_THRESHOLD=0.85
LAB_REPORT_CONFIDENCE_THRESHOLD=0.72
PRESCRIPTION_CONFIDENCE_THRESHOLD=0.80
FUZZY_MATCH_THRESHOLD=85
GROQ_API_KEY=